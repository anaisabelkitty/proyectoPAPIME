// ─────────────────────────────────────────────────────────────
//  PASO 2 — CALIBRACIÓN DE OFFSET (POT2)
//  Sensor pH PH-4502C | Arduino Mega 2560 | PlatformIO
//
//  ANTES DE SUBIR:
//    1. Desconecta la sonda del conector BNC
//    2. Cortocircuita el BNC: conecta un cable entre el pin central
//       (interior) y el anillo exterior del conector BNC
//
//  AL EJECUTAR:
//    - Abre el Serial Monitor a 9600 baudios
//    - Gira POT2 (el potenciómetro azul MÁS CERCANO al BNC)
//      hasta que el monitor diga "✔ CORRECTO"
//    - Cuando logres "✔ CORRECTO", deja el potenciómetro en esa posición
//    - Este ajuste NO se necesita repetir aunque cambies la sonda
//
//  AL TERMINAR:
//    - Quita el puente del BNC
//    - Restaura src/main_ph_medicion.cpp.bak como src/main.cpp
//      (o pasa al Paso 3: calibración con buffers)
//
//  CONEXIONES:
//    VCC del módulo  →  5V del Arduino Mega
//    GND del módulo  →  GND del Arduino Mega
//    Po  del módulo  →  A2 del Arduino Mega
//    BNC             →  cortocircuitado (pin central con anillo)
// ─────────────────────────────────────────────────────────────

#include <Arduino.h>

const int   PH_PIN   = A2;
const float VREF     = 5.0;
const float ADC_MAX  = 1024.0;
const int   MUESTRAS = 20;

// Lee el voltaje promediando MUESTRAS lecturas
float leerVoltaje() {
    long suma = 0;
    for (int i = 0; i < MUESTRAS; i++) {
        suma += analogRead(PH_PIN);
        delay(10);
    }
    float promedio = (float)suma / MUESTRAS;
    return promedio * VREF / ADC_MAX;
}

void setup() {
    Serial.begin(9600);
    pinMode(PH_PIN, INPUT);

    Serial.println("=========================================");
    Serial.println("  PASO 2 — AJUSTE DE OFFSET");
    Serial.println("  POT2 (el MAS CERCANO al BNC)");
    Serial.println("  Sensor pH PH-4502C");
    Serial.println("=========================================");
    Serial.println();
    Serial.println("  Asegurate de tener el BNC cortocircuitado.");
    Serial.println("  Gira POT2 (el mas CERCANO al BNC) hasta");
    Serial.println("  que el voltaje quede entre 2.48 V y 2.52 V.");
    Serial.println();
    Serial.println("  Voltaje  |  Estado");
    Serial.println("  ---------|---------");
}

void loop() {
    float voltaje = leerVoltaje();

    Serial.print("  ");
    Serial.print(voltaje, 4);
    Serial.print(" V  |  ");

    if (voltaje < 2.30) {
        Serial.println("⬆  Sube POT2 (voltaje muy bajo)");
    } else if (voltaje >= 2.30 && voltaje < 2.48) {
        Serial.println("⬆  Sube un poco mas POT2");
    } else if (voltaje >= 2.48 && voltaje <= 3.00) {
        Serial.println("✔  CORRECTO — deja el potenciometro aqui");
    } else if (voltaje > 3.00 && voltaje <= 3.20) {
        Serial.println("⬇  Baja un poco POT2");
    } else {
        Serial.println("⬇  Baja POT2 (voltaje muy alto)");
    }

    delay(500);
}
